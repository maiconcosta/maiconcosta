              "textGrowth": "fixed-width",
              "width": 520,
              "content": "const profile = {\n  name: 'Maicon Costa',\n  stack: ['Next.js', 'Node.js', 'Spring Boot'],\n  focus: ['performance', 'architecture', 'product']\n}\n\nasync function ship(value) {\n  return deploy({ cleanCode: true, scale: true, value })\n}",
